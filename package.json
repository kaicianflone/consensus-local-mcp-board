{
  "name": "consensus-local-mcp-board",
  "version": "0.1.0",
  "description": "Local-first MCP runtime for multi-agent consensus guard workflows",
  "type": "module",
  "bin": {
    "consensus-local-mcp-board": "bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "server/dist/",
    "shared/dist/",
    "web/dist/",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "start": "concurrently -k -n shared,server,web -c blue,green,magenta \"npm:start:shared\" \"npm:start:server\" \"npm:start:web\"",
    "start:verbose": "bash bin/dev-ui.sh --verbose",
    "start:shared": "npm --workspace shared run build:watch",
    "start:server": "npm --workspace server run dev",
    "start:web": "npm --workspace web run dev -- --open",
    "mcp:dev": "npm --workspace server run mcp:dev",
    "build": "npm --workspace shared run build && npm --workspace server run build && npm --workspace web run build",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "consensus",
    "guard",
    "workflow",
    "multi-agent",
    "hitl",
    "human-in-the-loop",
    "code-review",
    "voting",
    "audit",
    "sqlite"
  ],
  "author": "Kai Cianflone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaicianflone/consensus-local-mcp-board.git"
  },
  "homepage": "https://github.com/kaicianflone/consensus-local-mcp-board#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.0.1",
    "nanoid": "^5.1.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}

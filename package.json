{
  "name": "consensus-local-mcp-board",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "start": "concurrently -k -n shared,server,web -c blue,green,magenta \"npm:start:shared\" \"npm:start:server\" \"npm:start:web\"",
    "start:verbose": "bash bin/dev-ui.sh --verbose",
    "start:shared": "npm --workspace shared run build:watch",
    "start:server": "npm --workspace server run dev",
    "start:web": "npm --workspace web run dev -- --open",
    "mcp:dev": "npm --workspace server run mcp:dev",
    "build": "npm --workspace shared run build && npm --workspace server run build && npm --workspace web run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.0.1",
    "nanoid": "^5.1.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
